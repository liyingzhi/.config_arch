#
# wm independent hotkeys
#

# terminal emulator
ctrl + alt + k
	wmctrl -x -a kitty || kitty

ctrl + alt + t
	kitty

ctrl + alt + a
   flameshot gui

ctrl + alt + e
    wmctrl -x -a emacs || emacs


ctrl + alt + s
    wmctrl -x -a localsend || localsend

ctrl + alt + f
    wmctrl -x -a firefox || firefox

ctrl + alt + n
    wmctrl -x -a thunar || thunar

ctrl + alt + c
    bspc node -c

ctrl + shift + f
	bspc desktop -l next

ctrl+ alt + j
	bspc node -f prev.local.!hidden.window

# preselect the direction
ctrl + shift + {h,j,k,l}
	bspc node -p {west,south,north,east}

# run rofi combi
alt + space
    rofi -show combi -combi-modes window,drun,run,filebrowser -modes combi

# focus or send to the given desktop
alt + {_,shift + }{1-8}
	bspc {desktop -f,node -d} '^{1-8}'

# preselect the ratio
alt + ctrl + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
alt + ctrl + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
alt + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

alt + j
	bspc node -f prev.local.!hidden.window

alt + k
	bspc node -f next.local.!hidden.window

# focus the next/previous desktop in the current monitor
alt + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the last node/desktop
alt + Tab
	bspc node -f last

alt + grave
    bspc node -f next.window

alt + shift + grave
    bspc node -f prev.window

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

# quit/restart bspwm
super + ctrl + {q,r}
	bspc {quit,wm -r}


# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# send the newest marked node to the newest preselected node
super + y
	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest window
super + g
	bspc node -s biggest.window


# set the window state
super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# set the node flags
super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}


super + {Left,Right}
	bspc desktop -f {prev,next}

# move/resize
super + ctrl + shift + {h,j,k,l}
	bspc node -z {left -20 0,top 0 20,top 0 -20,left 20 0}


# move a floating window
super + ctrl + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}
